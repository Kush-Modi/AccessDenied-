# Supabase Settings (Backend DB and memory layers)
SUPABASE_URL=https://your-supabase-project-url.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-here

# Redis Cache Settings (Real-time agent logging & task queuing)
REDIS_URL=redis://localhost:6379/0

# Large Language Model API Settings (Inference for Planner & Action Planner)
GROQ_API_KEY=your-groq-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Resume Parsing Integration (Affinda API details)
AFFINDA_API_KEY=your-affinda-api-key-here
AFFINDA_WORKSPACE_ID=your-affinda-workspace-id-here
